@layout None
@page "/"
@using Users_DASM.Models
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@using Users_DASM.Services

@inject CurrentUserService CurrentUserService
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="css/login.css" />

<div class="login-shell">

    <!-- CLOSE BUTTON -->
    <button type="button"
            class="close-btn"
            title="Close">

        <i class="fas fa-times"></i>

    </button>

    <div class="login-container">

        <!-- HEADER -->
        <div class="login-header">

            <img src="images/logo_afp.png"
                 class="login-logo" />

            <h1 class="login-title">
                DASM-AFP
            </h1>


        </div>

        <!-- FORM -->
        <form @onsubmit="HandleLogin">

            <!-- USERNAME -->
            <div class="form-group">

                <div class="input-wrapper">

                    <i class="fas fa-user input-icon"></i>

                    <input type="text"
                           class="form-control"
                           placeholder="User ID"
                           @bind="loginModel.Username" />

                </div>

            </div>

            <!-- PASSWORD -->
            <div class="form-group">

                <div class="input-wrapper password-wrapper">

                    <i class="fas fa-lock input-icon"></i>

                    <input type="@passwordInputType"
                           class="form-control"
                           placeholder="Password"
                           @bind="loginModel.Password" />

                    <!-- TOGGLE -->
                    <button type="button"
                            class="toggle-btn"
                            @onclick="TogglePassword">

                        <i class="@passwordIcon"></i>

                    </button>

                </div>

            </div>

            <!-- ERROR -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="login-error">
                    @errorMessage
                </div>
            }

            <!-- LOGIN BUTTON -->
            <button type="submit"
                    class="btn btn-primary">

                Log In

            </button>

        </form>

    </div>

</div>

@code {

    // =========================================
    // LOGIN MODEL
    // =========================================

    private LoginRequest loginModel = new();

    // =========================================
    // UI
    // =========================================

    private string errorMessage = "";

    private string passwordInputType = "password";

    private string passwordIcon = "fas fa-eye";

    // =========================================
    // LOGIN
    // =========================================

    private async Task HandleLogin()
    {
        errorMessage = "";

        loginModel.AppType = "Personnel";

        try
        {
            var response =
                await Http.PostAsJsonAsync(
                    "api/auth/login",
                    loginModel);

            // =====================================
            // SUCCESS
            // =====================================

            if (response.IsSuccessStatusCode)
            {
                var user =
                    await response.Content
                    .ReadFromJsonAsync<UserSession>();

                if (user != null)
                {
                    // SAVE USER SESSION
                    await CurrentUserService
                        .SaveUser(user);

#if WINDOWS
AppWindowHolder.Instance.RestoreFullWindow();
#endif

                    // REDIRECT
                    await Task.Delay(100);

                    Nav.NavigateTo("/dashboard");
                }
            }

            // =====================================
            // ERROR
            // =====================================

            else
            {
                errorMessage =
                    await response.Content
                    .ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    // =========================================
    // TOGGLE PASSWORD
    // =========================================

    private void TogglePassword()
    {
        if (passwordInputType == "password")
        {
            passwordInputType = "text";

            passwordIcon = "fas fa-eye-slash";
        }
        else
        {
            passwordInputType = "password";

            passwordIcon = "fas fa-eye";
        }
    }

    // =========================================
    // LOGIN REQUEST
    // =========================================

    public class LoginRequest
    {
        public string Username { get; set; } = "";

        public string Password { get; set; } = "";

        public string AppType { get; set; } = "";
    }
}