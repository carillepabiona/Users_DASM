@layout None
@page "/"

@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop

@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="css/login.css" />

<div class="login-shell">

    <!-- CLOSE BUTTON -->
    <button type="button"
            class="close-btn"
            title="Close">

        <i class="fas fa-times"></i>

    </button>

    <div class="login-container">

        <!-- HEADER -->
        <div class="login-header">

            <img src="images/logo_afp.png"
                 class="login-logo" />

            <h1 class="login-title">
                DASM-AFP
            </h1>

            <p class="login-subtitle">
                Personnel Login
            </p>

        </div>

        <!-- FORM -->
        <form @onsubmit="HandleLogin">

            <!-- USERNAME -->
            <div class="form-group">

                <div class="input-wrapper">

                    <i class="fas fa-user input-icon"></i>

                    <input type="text"
                           class="form-control"
                           placeholder="Username"
                           @bind="loginModel.Username" />

                </div>

            </div>

            <!-- PASSWORD -->
            <div class="form-group">

                <div class="input-wrapper password-wrapper">

                    <i class="fas fa-lock input-icon"></i>

                    <input type="@passwordInputType"
                           class="form-control"
                           placeholder="Password"
                           @bind="loginModel.Password" />

                    <!-- TOGGLE -->
                    <button type="button"
                            class="toggle-btn"
                            @onclick="TogglePassword">

                        <i class="@passwordIcon"></i>

                    </button>

                </div>

            </div>

            <!-- ERROR -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="login-error">
                    @errorMessage
                </div>
            }

            <!-- LOGIN BUTTON -->
            <button type="submit"
                    class="btn btn-primary">

                Log In

            </button>

        </form>

    </div>

</div>

@code {

    private LoginRequest loginModel = new();

    private string errorMessage = "";

    private string passwordInputType = "password";

    private string passwordIcon = "fas fa-eye";

    private async Task HandleLogin()
    {
        // PERSONNEL APP
        loginModel.AppType = "Personnel";

        errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync(
                "https://localhost:7209/api/auth/login",
                loginModel);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content
                    .ReadFromJsonAsync<UserSession>();

                if (user != null)
                {
                    // SAVE SESSION
                    await JS.InvokeVoidAsync(
                        "localStorage.setItem",
                        "currentUser",
                        JsonSerializer.Serialize(user));

                    // REDIRECT
                    Nav.NavigateTo("/dashboard");
                }
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void TogglePassword()
    {
        if (passwordInputType == "password")
        {
            passwordInputType = "text";
            passwordIcon = "fas fa-eye-slash";
        }
        else
        {
            passwordInputType = "password";
            passwordIcon = "fas fa-eye";
        }
    }

    // LOGIN REQUEST
    public class LoginRequest
    {
        public string Username { get; set; } = "";

        public string Password { get; set; } = "";

        // Admin or Personnel
        public string AppType { get; set; } = "";
    }

    // USER SESSION
    public class UserSession
    {
        public string Id { get; set; } = "";

        public string Username { get; set; } = "";

        public string FullName { get; set; } = "";

        public int RoleId { get; set; }
    }
}