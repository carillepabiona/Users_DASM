@page "/upload-documents"
@using Users_DASM.Services
@inject DocumentStateService DocumentState
@inject CurrentUserService CurrentUserService
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Headers
@using System.Net.Http.Json

<head>
    <link rel="stylesheet" href="css/upload-documents.css" />
</head>

<div class="upload-container">

    <!-- Page Header -->
    <div class="page-header">
        <h1>📤 Upload Documents</h1>
        <p>Upload files and organize them in folders</p>
    </div>

    <!-- Main Content Grid -->
    <div class="upload-layout">

        <!-- Left Sidebar -->
        <aside class="folder-sidebar">

            <div class="sidebar-header">

                <h3>📁 Folders</h3>

                <button class="btn-new-folder"
                        @onclick="@(() => ShowNewFolderModal())"
                        title="Create Folder">

                    <i class="fas fa-plus"></i>

                </button>

            </div>

            <div class="folder-list">

                @foreach (var folder in folderList)
                {
                    <div class="folder-item @(selectedFolderId == folder.Id ? "active" : "")"
                         @onclick="@(() => SelectFolder(folder.Id))">

                        <i class="fas fa-folder"></i>

                        <span class="folder-name">
                            @folder.Name
                        </span>

                        <span class="folder-count">
                            @folder.FileCount
                        </span>

                    </div>
                }

            </div>

        </aside>

        <!-- Main Content -->
        <main class="upload-content">

            <!-- FILE PATH -->
            <div class="file-path-container">

                <div class="path-header">

                    <h4>📍 File Path</h4>

                    <button class="copy-path-btn"
                            @onclick="@(() => CopyPathToClipboard())">

                        <i class="fas fa-copy"></i>

                    </button>

                </div>

                <div class="file-path-display">

                    <div class="path-breadcrumb">

                        <span class="path-item root">

                            <i class="fas fa-folder-open"></i>

                            Documents

                        </span>

                        @if (selectedFolderId != null)
                        {
                            <span class="path-separator">\</span>

                            @foreach (var pathFolder in currentPath)
                            {
                                <span class="path-item">

                                    <i class="fas fa-folder"></i>

                                    @pathFolder.Name

                                </span>
                            }
                        }

                    </div>

                    <div class="path-text">
                        <code>@GetFullPath()</code>
                    </div>

                </div>

            </div>

            <!-- BREADCRUMB -->
            <div class="breadcrumb">

                <button class="breadcrumb-item"
                        @onclick="@(() => SelectFolder(null))">

                    <i class="fas fa-home"></i> Home

                </button>

                @if (selectedFolderId != null)
                {
                    <span class="breadcrumb-separator">/</span>

                    <span class="breadcrumb-item active">
                        @selectedFolderName
                    </span>
                }

            </div>

            <!-- UPLOAD AREA -->
            <div class="upload-area">

                <div class="upload-content-inner">

                    <div class="upload-icon">
                        <i class="fas fa-cloud-upload-alt"></i>
                    </div>

                    <h3>Drag and drop files here</h3>

                    <p>or</p>

                    <label for="file-input" class="upload-btn">

                        <i class="fas fa-folder-open"></i>

                        Choose Files

                    </label>

                    <InputFile id="file-input"
                               multiple
                               OnChange="HandleFileSelect"
                               style="display:none;" />

                    <p class="upload-info">

                        Supported formats:
                        PDF, DOCX, XLSX, PPTX, PNG, JPG, GIF

                        <br />

                        Max file size: 50 MB each

                    </p>

                    @if (selectedFolderId != null)
                    {
                        <div class="upload-destination">

                            <p class="destination-text">

                                <i class="fas fa-map-pin"></i>

                                Files will be uploaded to:

                                <strong>@GetFullPath()</strong>

                            </p>

                        </div>
                    }

                </div>

            </div>

            <!-- CATEGORY -->
            <div class="category-section">

                <div class="category-header">

                    <h3>📂 Select Category (Optional)</h3>

                    <button class="btn-new-folder"
                            @onclick="ShowCategoryModal">

                        <i class="fas fa-plus"></i>

                    </button>

                </div>

                <div class="category-buttons">

                    @foreach (var category in categories)
                    {
                        <button class="category-btn @(selectedCategory == category.Name ? "active" : "")"
                                @onclick="@(() => SelectCategory(category.Name))">

                            @GetCategoryIcon(category.Name)

                            @category.Name

                        </button>
                    }

                </div>

            </div>

            <!-- SUCCESS MESSAGE -->
            @if (!string.IsNullOrWhiteSpace(uploadSuccessMessage))
            {
                <div class="upload-success-box">

                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>

                    <div class="success-details">

                        <h3>Upload Successful!</h3>

                        <p>@uploadSuccessMessage</p>

                        <div class="success-path">

                            <i class="fas fa-folder-open"></i>

                            <code>@lastUploadedPath</code>

                        </div>

                    </div>

                </div>
            }

        </main>

    </div>

    <!-- CREATE FOLDER MODAL -->
    @if (showNewFolderModal)
    {
        <div class="modal-overlay"
             @onclick="@(() => showNewFolderModal = false)">

            <div class="modal-content"
                 @onclick:stopPropagation="true">

                <div class="modal-header">

                    <h2>📁 Create New Folder</h2>

                    <button class="modal-close"
                            @onclick="@(() => showNewFolderModal = false)">

                        <i class="fas fa-times"></i>

                    </button>

                </div>

                <div class="modal-body">

                    <div class="form-group">

                        <label>Folder Name</label>

                        <input type="text"
                               class="form-control"
                               @bind="newFolderName" />

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="@(() => showNewFolderModal = false)">

                        Cancel

                    </button>

                    <button class="btn btn-primary"
                            @onclick="CreateNewFolder">

                        Create Folder

                    </button>

                </div>

            </div>

        </div>
    }

    <!-- CREATE CATEGORY MODAL -->
    @if (showCategoryModal)
    {
        <div class="modal-overlay"
             @onclick="@(() => showCategoryModal = false)">

            <div class="modal-content"
                 @onclick:stopPropagation="true">

                <div class="modal-header">

                    <h2>📂 Create Category</h2>

                    <button class="modal-close"
                            @onclick="@(() => showCategoryModal = false)">

                        <i class="fas fa-times"></i>

                    </button>

                </div>

                <div class="modal-body">

                    <div class="form-group">

                        <label>Category Name</label>

                        <input type="text"
                               class="form-control"
                               @bind="newCategoryName" />

                    </div>

                    <div class="form-group">

                        <label>Description</label>

                        <textarea class="form-control"
                                  @bind="newCategoryDescription">
                        </textarea>

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="@(() => showCategoryModal = false)">

                        Cancel

                    </button>

                    <button class="btn btn-primary"
                            @onclick="CreateCategory">

                        Create Category

                    </button>

                </div>

            </div>

        </div>
    }

</div>

@code {

    // ======================================
    // CURRENT USER
    // ======================================

    private Guid currentUserId;

    private UserSession? currentUser;

    [Inject]
    HttpClient Http { get; set; }

    private List<FolderModel> folderList = new();

    private List<PathFolderModel> currentPath = new();

    private List<CategoryModel> categories = new();

    private Guid? selectedFolderId = null;

    private string selectedFolderName = "";

    private string selectedCategory = "";

    private bool showNewFolderModal = false;

    private bool showCategoryModal = false;

    private string newFolderName = "";

    private string newCategoryName = "";

    private string newCategoryDescription = "";

    private string uploadSuccessMessage = "";

    private string lastUploadedPath = "";

    private double usedStorage = 0;

    private double totalStorage = 100;

    private double storagePercentage =>
        totalStorage == 0
        ? 0
        : (usedStorage / totalStorage) * 100;

    protected override async Task OnInitializedAsync()
    {
        // ============================
        // GET CURRENT USER
        // ============================

        currentUser =
            await CurrentUserService.GetUser();

        if (currentUser == null)
        {
            return;
        }

        currentUserId = currentUser.Id;

        // ============================
        // LOAD PAGE DATA
        // ============================

        await LoadFolders();

        await LoadCategories();
    }

    // ======================================
    // LOAD FOLDERS
    // ======================================

    private async Task LoadFolders()
    {
        var response =
            await Http.GetFromJsonAsync<List<FolderResponse>>(
                "api/folders");

        if (response != null)
        {
            folderList = response.Select(x => new FolderModel
            {
                Id = x.Id,
                Name = x.Name,
                FileCount = x.FileCount,
                ParentFolderId = x.ParentFolderId
            }).ToList();
        }
    }

    // ======================================
    // LOAD CATEGORIES
    // ======================================

    private async Task LoadCategories()
    {
        var response =
            await Http.GetFromJsonAsync<List<CategoryModel>>(
                "api/categories");

        if (response != null)
        {
            categories = response;
        }
    }

    // ======================================
    // CREATE CATEGORY
    // ======================================

    private void ShowCategoryModal()
    {
        showCategoryModal = true;
    }

    private async Task CreateCategory()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(newCategoryName))
            {
                Console.WriteLine("Category name required.");
                return;
            }

            var request = new
            {
                Name = newCategoryName,
                Description = newCategoryDescription
            };

            var response =
                await Http.PostAsJsonAsync(
                    "api/categories",
                    request);

            if (response.IsSuccessStatusCode)
            {
                newCategoryName = "";

                newCategoryDescription = "";

                showCategoryModal = false;

                await LoadCategories();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }

    // ======================================
    // CREATE FOLDER
    // ======================================

    private void ShowNewFolderModal()
    {
        showNewFolderModal = true;
    }

    private async Task CreateNewFolder()
    {
        var request = new
        {
            Name = newFolderName,
            ParentFolderId = selectedFolderId,
            CreatedBy = currentUserId
        };

        var response =
            await Http.PostAsJsonAsync(
                "api/folders",
                request);

        if (response.IsSuccessStatusCode)
        {
            newFolderName = "";

            showNewFolderModal = false;

            await LoadFolders();
        }
    }

    // ======================================
    // SELECT CATEGORY
    // ======================================

    private void SelectCategory(string category)
    {
        selectedCategory =
            selectedCategory == category
            ? ""
            : category;
    }

    // ======================================
    // SELECT FOLDER
    // ======================================

    private void SelectFolder(Guid? folderId)
    {
        selectedFolderId = folderId;

        currentPath.Clear();

        if (folderId == null)
        {
            selectedFolderName = "Home";
            return;
        }

        var pathStack = new Stack<PathFolderModel>();

        var currentFolder =
            folderList.FirstOrDefault(x => x.Id == folderId);

        while (currentFolder != null)
        {
            pathStack.Push(new PathFolderModel
            {
                Id = currentFolder.Id,
                Name = currentFolder.Name
            });

            if (currentFolder.ParentFolderId == null)
                break;

            currentFolder =
                folderList.FirstOrDefault(
                    x => x.Id == currentFolder.ParentFolderId);
        }

        currentPath = pathStack.ToList();

        selectedFolderName =
            currentPath.LastOrDefault()?.Name ?? "Home";
    }

    // ======================================
    // HELPERS
    // ======================================

    private string GetFullPath()
    {
        var path = "My Documents";

        foreach (var folder in currentPath)
        {
            path += $"\\{folder.Name}";
        }

        return path;
    }

    private void CopyPathToClipboard()
    {
    }

    // ======================================
    // UPLOAD FILE
    // ======================================

    private async Task HandleFileSelect(
        InputFileChangeEventArgs e)
    {
        uploadSuccessMessage = "";

        lastUploadedPath = "";

        var files = e.GetMultipleFiles();

        foreach (var file in files)
        {
            var content =
                new MultipartFormDataContent();

            var fileContent =
                new StreamContent(
                    file.OpenReadStream(52428800));

            fileContent.Headers.ContentType =
                new MediaTypeHeaderValue(
                    file.ContentType);

            content.Add(
                fileContent,
                "file",
                file.Name);

            content.Add(
                new StringContent(selectedCategory ?? ""),
                "category");

            if (selectedFolderId != null)
            {
                content.Add(
                    new StringContent(
                        selectedFolderId.ToString()),
                    "folderId");
            }

                content.Add(
                     new StringContent(
                         currentUserId.ToString()),
                     "uploadedBy");

            var response =
                await Http.PostAsync(
                    "api/documents/upload",
                    content);

            if (response.IsSuccessStatusCode)
            {
                lastUploadedPath =
                    $"{GetFullPath()}\\{file.Name}";

                uploadSuccessMessage =
                    $"The document '{file.Name}' was uploaded successfully.";

                await LoadFolders();
            }
            else
            {
                uploadSuccessMessage =
                    $"Failed to upload '{file.Name}'.";
            }
        }
    }

    // ======================================
    // FILE HELPERS
    // ======================================

    private string GetCategoryIcon(string category) => category switch
    {
        "Reports" => "📊",
        "Contracts" => "📋",
        "Invoices" => "💰",
        "Presentations" => "🎨",
        _ => "📁"
    };

    // ======================================
    // MODELS
    // ======================================

    public class FolderModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public int FileCount { get; set; }

        public Guid? ParentFolderId { get; set; }
    }

    public class PathFolderModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }
    }

    public class FolderResponse
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public int FileCount { get; set; }

        public Guid? ParentFolderId { get; set; }
    }

    public class CategoryModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }
    }
}