@page "/upload-documents"

@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Headers
@using System.Net.Http.Json

<head>
    <link rel="stylesheet" href="css/upload-documents.css" />
</head>

<div class="upload-container">

    <!-- Page Header -->
    <div class="page-header">
        <h1>📤 Upload Documents</h1>
        <p>Upload files and organize them in folders</p>
    </div>

    <!-- Main Content Grid -->
    <div class="upload-layout">

        <!-- Left Sidebar -->
        <aside class="folder-sidebar">

            <div class="sidebar-header">

                <h3>📁 Folders</h3>

                <button class="btn-new-folder"
                        @onclick="@(() => ShowNewFolderModal())"
                        title="Create Folder">

                    <i class="fas fa-plus"></i>

                </button>

            </div>

            <div class="folder-list">

                @foreach (var folder in folderList)
                {
                    <div class="folder-item @(selectedFolderId == folder.Id ? "active" : "")"
                         @onclick="@(() => SelectFolder(folder.Id))">

                        <i class="fas fa-folder"></i>

                        <span class="folder-name">
                            @folder.Name
                        </span>

                        <span class="folder-count">
                            @folder.FileCount
                        </span>

                    </div>
                }

            </div>

            <div class="sidebar-footer">

                <p class="storage-label">
                    Storage Used
                </p>

                <div class="storage-bar">

                    <div class="storage-progress"
                         style="width:@storagePercentage%">
                    </div>

                </div>

                <p class="storage-text">
                    @usedStorage GB / @totalStorage GB
                </p>

            </div>

        </aside>

        <!-- Main Content -->
        <main class="upload-content">

            <!-- FILE PATH -->
            <div class="file-path-container">

                <div class="path-header">

                    <h4>📍 File Path</h4>

                    <button class="copy-path-btn"
                            @onclick="@(() => CopyPathToClipboard())">

                        <i class="fas fa-copy"></i>

                    </button>

                </div>

                <div class="file-path-display">

                    <div class="path-breadcrumb">

                        <span class="path-item root">

                            <i class="fas fa-folder-open"></i>

                            Documents

                        </span>

                        @if (selectedFolderId != null)
                        {
                            <span class="path-separator">\</span>

                            @foreach (var pathFolder in currentPath)
                            {
                                <span class="path-item">

                                    <i class="fas fa-folder"></i>

                                    @pathFolder.Name

                                </span>
                            }
                        }

                    </div>

                    <div class="path-text">
                        <code>@GetFullPath()</code>
                    </div>

                </div>

            </div>

            <!-- BREADCRUMB -->
            <div class="breadcrumb">

                <button class="breadcrumb-item"
                        @onclick="@(() => SelectFolder(null))">

                    <i class="fas fa-home"></i> Home

                </button>

                @if (selectedFolderId != null)
                {
                    <span class="breadcrumb-separator">/</span>

                    <span class="breadcrumb-item active">
                        @selectedFolderName
                    </span>
                }

            </div>

            <!-- UPLOAD AREA -->
            <div class="upload-area">

                <div class="upload-content-inner">

                    <div class="upload-icon">
                        <i class="fas fa-cloud-upload-alt"></i>
                    </div>

                    <h3>Drag and drop files here</h3>

                    <p>or</p>

                    <label for="file-input" class="upload-btn">

                        <i class="fas fa-folder-open"></i>

                        Choose Files

                    </label>

                    <InputFile id="file-input"
                               multiple
                               OnChange="HandleFileSelect"
                               style="display:none;" />

                    <p class="upload-info">

                        Supported formats:
                        PDF, DOCX, XLSX, PPTX, PNG, JPG, GIF

                        <br />

                        Max file size: 50 MB each

                    </p>

                    @if (selectedFolderId != null)
                    {
                        <div class="upload-destination">

                            <p class="destination-text">

                                <i class="fas fa-map-pin"></i>

                                Files will be uploaded to:

                                <strong>@GetFullPath()</strong>

                            </p>

                        </div>
                    }

                </div>

            </div>

            <!-- CATEGORY -->
            <div class="category-section">

                <div class="category-header">

                    <h3>📂 Select Category (Optional)</h3>

                    <button class="btn-new-folder"
                            @onclick="ShowCategoryModal">

                        <i class="fas fa-plus"></i>

                    </button>

                </div>

                <div class="category-buttons">

                    @foreach (var category in categories)
                    {
                        <button class="category-btn @(selectedCategory == category.Name ? "active" : "")"
                                @onclick="@(() => SelectCategory(category.Name))">

                            @GetCategoryIcon(category.Name)

                            @category.Name

                        </button>
                    }

                </div>

            </div>

            <!-- RECENT UPLOADS -->
            <div class="recent-uploads-section">

                <div class="section-header">

                    <h2>📋 Recent Uploads</h2>

                    <select class="sort-dropdown"
                            @onchange="@((ChangeEventArgs e) => ChangeSortOrder(e.Value?.ToString()))">

                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                        <option value="name">Name (A-Z)</option>
                        <option value="size">Size (Largest)</option>

                    </select>

                </div>

                <!-- UPLOADING -->
                @if (uploadingFiles.Count > 0)
                {
                    <div class="upload-progress-section">

                        @foreach (var uploadFile in uploadingFiles)
                        {
                            <div class="upload-progress-item">

                                <div class="progress-info">

                                    <p class="progress-filename">
                                        @uploadFile.Name
                                    </p>

                                    <p class="progress-status">
                                        @uploadFile.Status
                                    </p>

                                    <p class="progress-path">

                                        <i class="fas fa-folder-open"></i>

                                        @uploadFile.UploadPath

                                    </p>

                                </div>

                                <div class="progress-bar">

                                    <div class="progress-fill"
                                         style="width:@uploadFile.Progress%">
                                    </div>

                                </div>

                                <p class="progress-percentage">
                                    @uploadFile.Progress%
                                </p>

                            </div>
                        }

                    </div>
                }

                <!-- FILE LIST -->
                <div class="files-list">

                    @if (recentUploads.Count == 0)
                    {
                        <div class="empty-state">

                            <i class="fas fa-inbox"></i>

                            <p>No files uploaded yet</p>

                        </div>
                    }
                    else
                    {
                        @foreach (var file in recentUploads)
                        {
                            <div class="file-item"
                                 @onmouseenter="@(() => ActiveFileId = file.Id)"
                                 @onmouseleave="@(() => ActiveFileId = null)">

                                <div class="file-left">

                                    <div class="file-icon"
                                         style="background-color:@GetFileColor(file.Type)">

                                        @GetFileIcon(file.Type)

                                    </div>

                                    <div class="file-details">

                                        <h4 class="file-name">
                                            @file.Name
                                        </h4>

                                        <p class="file-meta">

                                            @file.Size |
                                            @file.UploadedDate

                                            @if (!string.IsNullOrWhiteSpace(file.Category))
                                            {
                                                <span> | @file.Category</span>
                                            }

                                        </p>

                                        <p class="file-path">

                                            <i class="fas fa-folder-open"></i>

                                            @file.FilePath

                                        </p>

                                    </div>

                                </div>

                                <div class="file-status">

                                    <span class="status-badge success">

                                        <i class="fas fa-check-circle"></i>

                                        Completed

                                    </span>

                                </div>

                                @if (ActiveFileId == file.Id)
                                {
                                    <div class="file-actions">

                                        <button class="action-btn"
                                                title="Download"
                                                @onclick="@(() => HandleDownloadFile(file))">

                                            <i class="fas fa-download"></i>

                                        </button>

                                        <button class="action-btn delete"
                                                title="Delete"
                                                @onclick="@(() => HandleDeleteFile(file))">

                                            <i class="fas fa-trash"></i>

                                        </button>

                                    </div>
                                }

                            </div>
                        }
                    }

                </div>

            </div>

        </main>

    </div>

    <!-- CREATE FOLDER MODAL -->
    @if (showNewFolderModal)
    {
        <div class="modal-overlay"
             @onclick="@(() => showNewFolderModal = false)">

            <div class="modal-content"
                 @onclick:stopPropagation="true">

                <div class="modal-header">

                    <h2>📁 Create New Folder</h2>

                    <button class="modal-close"
                            @onclick="@(() => showNewFolderModal = false)">

                        <i class="fas fa-times"></i>

                    </button>

                </div>

                <div class="modal-body">

                    <div class="form-group">

                        <label>Folder Name</label>

                        <input type="text"
                               class="form-control"
                               @bind="newFolderName" />

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="@(() => showNewFolderModal = false)">

                        Cancel

                    </button>

                    <button class="btn btn-primary"
                            @onclick="CreateNewFolder">

                        Create Folder

                    </button>

                </div>

            </div>

        </div>
    }

    <!-- CREATE CATEGORY MODAL -->
    @if (showCategoryModal)
    {
        <div class="modal-overlay"
             @onclick="@(() => showCategoryModal = false)">

            <div class="modal-content"
                 @onclick:stopPropagation="true">

                <div class="modal-header">

                    <h2>📂 Create Category</h2>

                    <button class="modal-close"
                            @onclick="@(() => showCategoryModal = false)">

                        <i class="fas fa-times"></i>

                    </button>

                </div>

                <div class="modal-body">

                    <div class="form-group">

                        <label>Category Name</label>

                        <input type="text"
                               class="form-control"
                               @bind="newCategoryName" />

                    </div>

                    <div class="form-group">

                        <label>Description</label>

                        <textarea class="form-control"
                                  @bind="newCategoryDescription">
                        </textarea>

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="@(() => showCategoryModal = false)">

                        Cancel

                    </button>

                    <button class="btn btn-primary"
                            @onclick="CreateCategory">

                        Create Category

                    </button>

                </div>

            </div>

        </div>
    }

</div>

@code {

    [Inject]
    HttpClient Http { get; set; }

    private List<FolderModel> folderList = new();

    private List<PathFolderModel> currentPath = new();

    private List<FileModel> recentUploads = new();

    private List<UploadingFileModel> uploadingFiles = new();

    private List<CategoryModel> categories = new();

    private Guid? selectedFolderId = null;

    private string selectedFolderName = "";

    private string selectedCategory = "";

    private Guid? ActiveFileId = null;

    private bool showNewFolderModal = false;

    private bool showCategoryModal = false;

    private string newFolderName = "";

    private string newCategoryName = "";

    private string newCategoryDescription = "";

    private double usedStorage = 0;

    private double totalStorage = 100;

    private double storagePercentage =>
        totalStorage == 0
        ? 0
        : (usedStorage / totalStorage) * 100;

    protected override async Task OnInitializedAsync()
    {
        await LoadFolders();

        await LoadCategories();

        await LoadDocuments();
    }

    // ======================================
    // LOAD FOLDERS
    // ======================================

    private async Task LoadFolders()
    {
        var response =
            await Http.GetFromJsonAsync<List<FolderResponse>>(
                "http://192.168.11.10:5043/api/folders");

        if (response != null)
        {
            folderList = response.Select(x => new FolderModel
            {
                Id = x.Id,
                Name = x.Name,
                FileCount = x.FileCount,
                ParentFolderId = x.ParentFolderId
            }).ToList();
        }
    }

    // ======================================
    // LOAD CATEGORIES
    // ======================================

    private async Task LoadCategories()
    {
        var response =
            await Http.GetFromJsonAsync<List<CategoryModel>>(
                "http://192.168.11.10:5043/api/categories");

        if (response != null)
        {
            categories = response;
        }
    }

    // ======================================
    // LOAD DOCUMENTS
    // ======================================

    private async Task LoadDocuments()
    {
        var response =
            await Http.GetFromJsonAsync<List<DocumentResponse>>(
                "http://192.168.11.10:5043/api/documents");

        if (response != null)
        {
            recentUploads = response.Select(x => new FileModel
            {
                Id = x.Id,
                Name = x.OriginalFileName,
                Type = GetFileType(x.OriginalFileName),
                Size = FormatFileSize(x.FileSize),
                UploadedDate = x.CreatedAt.ToString("MMM dd, yyyy"),
                Category = x.Category,
                FilePath = BuildDocumentPath(
                    x.StoragePath,
                    x.OriginalFileName),
                Status = "completed",
                UploadedBy = x.UploadedBy,
                UserLevel = x.UserLevel
            }).ToList();

            usedStorage =
                response.Sum(x => x.FileSize)
                / 1024d / 1024d / 1024d;
        }
    }

    // ======================================
    // CREATE CATEGORY
    // ======================================

    private void ShowCategoryModal()
    {
        showCategoryModal = true;
    }

    private async Task CreateCategory()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(newCategoryName))
            {
                Console.WriteLine("Category name required.");
                return;
            }

            var request = new
            {
                Name = newCategoryName,
                Description = newCategoryDescription
            };

            var response =
                await Http.PostAsJsonAsync(
                    "http://192.168.11.10:5043/api/categories",
                    request);

            var message =
                await response.Content.ReadAsStringAsync();

            Console.WriteLine(message);

            if (response.IsSuccessStatusCode)
            {
                newCategoryName = "";

                newCategoryDescription = "";

                showCategoryModal = false;

                await LoadCategories();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }

    // ======================================
    // CREATE FOLDER
    // ======================================

    private void ShowNewFolderModal()
    {
        showNewFolderModal = true;
    }

    private async Task CreateNewFolder()
    {
        var request = new
        {
            Name = newFolderName,
            ParentFolderId = selectedFolderId,
            CreatedBy = "9136564a-c20f-4208-86a3-22d665c8df56"
        };

        var response =
            await Http.PostAsJsonAsync(
                "http://192.168.11.10:5043/api/folders",
                request);

        if (response.IsSuccessStatusCode)
        {
            newFolderName = "";

            showNewFolderModal = false;

            await LoadFolders();
        }
    }

    // ======================================
    // SELECT CATEGORY
    // ======================================

    private void SelectCategory(string category)
    {
        selectedCategory =
            selectedCategory == category
            ? ""
            : category;
    }

    // ======================================
    // SELECT FOLDER
    // ======================================

    private void SelectFolder(Guid? folderId)
    {
        selectedFolderId = folderId;

        currentPath.Clear();

        if (folderId == null)
        {
            selectedFolderName = "Home";
            return;
        }

        var pathStack = new Stack<PathFolderModel>();

        var currentFolder =
            folderList.FirstOrDefault(x => x.Id == folderId);

        while (currentFolder != null)
        {
            pathStack.Push(new PathFolderModel
            {
                Id = currentFolder.Id,
                Name = currentFolder.Name
            });

            if (currentFolder.ParentFolderId == null)
                break;

            currentFolder =
                folderList.FirstOrDefault(
                    x => x.Id == currentFolder.ParentFolderId);
        }

        currentPath = pathStack.ToList();

        selectedFolderName =
            currentPath.LastOrDefault()?.Name ?? "Home";
    }

    // ======================================
    // HELPERS
    // ======================================

    private string GetFullPath()
    {
        var path = "My Documents";

        foreach (var folder in currentPath)
        {
            path += $"\\{folder.Name}";
        }

        return path;
    }

    private string BuildDocumentPath(
    string storagePath,
    string fileName)
    {
        if (string.IsNullOrWhiteSpace(storagePath))
        {
            return $"My Documents\\{fileName}";
        }

        storagePath =
            storagePath.Replace("/", "\\");

        if (!storagePath.StartsWith("My Documents"))
        {
            storagePath = $"My Documents\\{storagePath}";
        }

        return $"{storagePath}\\{fileName}";
    }

    private void CopyPathToClipboard()
    {
    }

    private void ChangeSortOrder(string sortOrder)
    {
    }

    private void HandleDownloadFile(FileModel file)
    {
    }

    private async Task HandleDeleteFile(FileModel file)
    {
        await Http.DeleteAsync(
            $"http://192.168.11.10:5043/api/documents/{file.Id}");

        await LoadDocuments();
    }

    // ======================================
    // UPLOAD FILE
    // ======================================

    private async Task HandleFileSelect(
        InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();

        foreach (var file in files)
        {
            var upload =
                new UploadingFileModel
                {
                    Name = file.Name,
                    Progress = 10,
                    Status = "Preparing...",
                    UploadPath = GetFullPath()
                };

            uploadingFiles.Add(upload);

            var content =
                new MultipartFormDataContent();

            var fileContent =
                new StreamContent(
                    file.OpenReadStream(52428800));

            fileContent.Headers.ContentType =
                new MediaTypeHeaderValue(
                    file.ContentType);

            content.Add(
                fileContent,
                "file",
                file.Name);

            content.Add(
                new StringContent(selectedCategory),
                "category");

            if (selectedFolderId != null)
            {
                content.Add(
                    new StringContent(
                        selectedFolderId.ToString()),
                    "folderId");
            }

            content.Add(
                new StringContent(
                    "9136564a-c20f-4208-86a3-22d665c8df56"),
                "uploadedBy");

            upload.Progress = 50;

            upload.Status = "Uploading...";

            var response =
                await Http.PostAsync(
                    "http://192.168.11.10:5043/api/documents/upload",
                    content);

            if (response.IsSuccessStatusCode)
            {
                upload.Progress = 100;

                upload.Status = "Completed";

                await LoadDocuments();

                await LoadFolders();
            }
            else
            {
                upload.Progress = 0;

                upload.Status = "Failed";
            }
        }
    }

    // ======================================
    // FILE HELPERS
    // ======================================

    private string GetFileType(string fileName)
    {
        var ext =
            Path.GetExtension(fileName).ToLower();

        return ext switch
        {
            ".pdf" => "pdf",
            ".doc" or ".docx" => "word",
            ".xls" or ".xlsx" => "excel",
            ".ppt" or ".pptx" => "powerpoint",
            ".png" or ".jpg" or ".jpeg" => "image",
            _ => "file"
        };
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
        {
            return $"{bytes / 1024f / 1024f:0.##} MB";
        }

        return $"{bytes / 1024f:0.##} KB";
    }

    private string GetFileIcon(string type) => type switch
    {
        "pdf" => "📄",
        "word" => "📝",
        "excel" => "📊",
        "powerpoint" => "🎨",
        "image" => "🖼️",
        _ => "📁"
    };

    private string GetFileColor(string type) => type switch
    {
        "pdf" => "#d32f2f",
        "word" => "#2196F3",
        "excel" => "#1f7e3a",
        "powerpoint" => "#f57c00",
        "image" => "#9c27b0",
        _ => "#666666"
    };

    private string GetCategoryIcon(string category) => category switch
    {
        "Reports" => "📊",
        "Contracts" => "📋",
        "Invoices" => "💰",
        "Presentations" => "🎨",
        _ => "📁"
    };

    // ======================================
    // MODELS
    // ======================================

    public class FolderModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public int FileCount { get; set; }

        public Guid? ParentFolderId { get; set; }
    }

    public class PathFolderModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }
    }

    public class FileModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public string Type { get; set; }

        public string Size { get; set; }

        public string UploadedDate { get; set; }

        public string Category { get; set; }

        public string Status { get; set; }

        public string FilePath { get; set; }

        public string UploadedBy { get; set; }

        public string UserLevel { get; set; }
    }

    public class UploadingFileModel
    {
        public string Name { get; set; }

        public int Progress { get; set; }

        public string Status { get; set; }

        public string UploadPath { get; set; }
    }

    public class FolderResponse
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public int FileCount { get; set; }

        public Guid? ParentFolderId { get; set; }
    }

    public class CategoryModel
    {
        public Guid Id { get; set; }

        public string Name { get; set; }
    }

    public class DocumentResponse
    {
        public Guid Id { get; set; }

        public string OriginalFileName { get; set; }

        public long FileSize { get; set; }

        public string StoragePath { get; set; }

        public DateTime CreatedAt { get; set; }

        public string Category { get; set; }

        public string UploadedBy { get; set; }

        public string UserLevel { get; set; }
    }
}