@page "/documents"

@using System.Net.Http.Json
@using System.Linq

@inject NavigationManager Navigation
@inject HttpClient Http

<head>
    <link rel="stylesheet" href="css/documents.css" />
</head>

<PageTitle>Documents</PageTitle>

<div class="documents-container">

    <!-- Header -->
    <div class="documents-header">

        <div class="header-content">

            <h1>📄 Documents</h1>

            <p class="subtitle">
                Manage your files, folders, and categories
            </p>

        </div>

    </div>

    <!-- Search and Filter Bar -->
    <div class="search-bar">

        <div class="search-input-wrapper">

            <span class="search-icon">🔍</span>

            <input type="text"
                   class="search-input"
                   placeholder="Search documents..."
                   @bind="searchQuery"
                   @oninput="@((ChangeEventArgs e) => FilterDocuments(e.Value?.ToString() ?? ""))" />

        </div>

        <select class="filter-select"
                @onchange="FilterByCategory">

            <option value="">
                All Categories
            </option>

            @foreach (var category in categories)
            {
                <option value="@category">
                    @category
                </option>
            }

        </select>

        <select class="filter-select"
                @onchange="SortDocuments">

            <option value="recent">
                Recently Modified
            </option>

            <option value="name">
                Name (A-Z)
            </option>

            <option value="size">
                File Size
            </option>

            <option value="oldest">
                Oldest First
            </option>

        </select>

    </div>

    <!-- Breadcrumb -->
    <div class="breadcrumb">

        <span class="breadcrumb-item active"
              @onclick="GoHome"
              style="cursor:pointer">

            📁 My Documents

        </span>

        @if (!string.IsNullOrEmpty(currentFolder))
        {
            <span class="breadcrumb-separator">/</span>

            <span class="breadcrumb-item">
                @currentFolder
            </span>
        }

    </div>

    <!-- Category Pills -->
    <div class="category-pills">

        @foreach (var category in categories)
        {
            <button class="category-pill @(selectedCategory == category ? "active" : "")"
                    @onclick="@(() => SelectCategory(category))">

                @GetCategoryIcon(category)
                @category

            </button>
        }

    </div>

    <!-- FOLDERS -->
    @if (folders.Any())
    {
        <div class="section-title">
            📁 Folders
        </div>

        <div class="folders-grid">

            @foreach (var folder in folders)
            {
                <div class="folder-card"
                     @onclick="@(() => OpenFolder(folder.Id, folder.Name))">

                    <div class="folder-icon">

                        <span class="folder-emoji">
                            📁
                        </span>

                        <span class="folder-count">
                            @folder.DocumentCount
                        </span>

                    </div>

                    <div class="folder-info">

                        <p class="folder-name">
                            @folder.Name
                        </p>

                        <p class="folder-meta">
                            @folder.DocumentCount documents
                        </p>

                        <p class="folder-modified">
                            Modified:
                            @folder.LastModified.ToString("MMM dd, yyyy")
                        </p>

                    </div>

                    <div class="folder-actions">

                        <button class="action-icon"
                                title="Delete"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => DeleteFolder(folder.Id))">

                            🗑️

                        </button>

                    </div>

                </div>
            }

        </div>
    }

    <!-- DOCUMENTS -->
    <div class="section-title">
        📄 Documents
    </div>

    @if (filteredDocuments.Any())
    {
        <div class="documents-grid">

            @foreach (var doc in filteredDocuments)
            {
                <div class="document-card"
                     @onclick="@(() => SelectDocument(doc))">

                    <!-- THUMBNAIL -->
                    <div class="document-thumbnail">

                        <div class="file-icon"
                             style="background-color:@GetFileColor(doc.FileType)">

                            @GetFileIcon(doc.FileType)

                        </div>

                        <div class="action-overlay"
                             @onclick:stopPropagation="true">

                            <div class="action-buttons">

                                <button class="action-btn view-btn"
                                        title="View"
                                        @onclick="@(() => ViewDocument(doc))">

                                    👁️

                                </button>

                                <button class="action-btn edit-btn"
                                        title="Edit"
                                        @onclick="@(() => EditDocument(doc))">

                                    ✏️

                                </button>

                                <button class="action-btn share-btn"
                                        title="Share"
                                        @onclick="@(() => ShareDocument(doc))">

                                    📤

                                </button>

                                <button class="action-btn download-btn"
                                        title="Download"
                                        @onclick="@(() => DownloadDocument(doc))">

                                    ⬇️

                                </button>

                                <button class="action-btn delete-btn"
                                        title="Delete"
                                        @onclick="@(() => DeleteDocument(doc))">

                                    🗑️

                                </button>

                            </div>

                        </div>

                    </div>

                    <!-- INFO -->
                    <div class="document-info">

                        <h3 class="document-name">
                            @doc.Name
                        </h3>

                        <div class="document-meta">

                            <span class="file-size">
                                @FormatFileSize(doc.Size)
                            </span>

                            <span class="file-date">
                                @doc.UploadDate.ToString("MMM dd")
                            </span>

                        </div>

                        <p class="document-category">

                            <span class="category-badge">
                                @doc.Category
                            </span>

                        </p>

                        <p class="document-owner">

                            Uploaded by:
                            <strong>@doc.UploadedBy</strong>

                        </p>

                        <p class="document-time">

                            @GetRelativeTime(doc.UploadDate)

                        </p>

                        <!-- FILE PATH -->
                        <p class="document-path">

                            📁 @doc.FilePath

                        </p>

                    </div>

                    <!-- MOBILE ACTIONS -->
                    <div class="quick-actions-mobile">

                        <button class="quick-action-btn"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => ViewDocument(doc))">

                            View

                        </button>

                        <button class="quick-action-btn"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => DownloadDocument(doc))">

                            Download

                        </button>

                        <button class="quick-action-btn"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => DeleteDocument(doc))">

                            Delete

                        </button>

                    </div>

                </div>
            }

        </div>
    }
    else if (!string.IsNullOrEmpty(searchQuery)
    || !string.IsNullOrEmpty(selectedCategory)
    || currentFolderId != null)
    {
        <div class="empty-state">

            <div class="empty-icon">
                🔍
            </div>

            <h2>
                No Documents Found
            </h2>

            <p>
                Try adjusting your search filters or upload a new document.
            </p>

            <button class="btn btn-primary"
                    @onclick="ClearFilters">

                Clear Filters

            </button>

        </div>
    }
    else
    {
        <div class="empty-state">

            <div class="empty-icon">
                📭
            </div>

            <h2>
                No Documents Yet
            </h2>

            <p>
                Start by uploading your first document or creating a folder.
            </p>

            <button class="btn btn-primary"
                    @onclick="ShowUploadModal">

                Upload Document

            </button>

        </div>
    }

</div>

@code {

    private string searchQuery = "";

    private string selectedCategory = "";

    private string currentFolder = "";

    private Guid? currentFolderId = null;

    private string sortBy = "recent";

    private List<DocumentItem> documents = new();

    private List<DocumentItem> filteredDocuments = new();

    private List<FolderItem> folders = new();

    private List<string> categories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();

        await LoadFolders();

        await LoadDocuments();
    }

    // =========================================
    // LOAD DOCUMENTS
    // =========================================

    private async Task LoadDocuments()
    {
        try
        {
            var response =
                await Http.GetFromJsonAsync<List<DocumentResponse>>(
                    "http://192.168.11.10:5043/api/documents");

            if (response != null)
            {
                documents =
                    response.Select(x => new DocumentItem
                    {
                        Id = x.Id,

                        Name = x.OriginalFileName,

                        FileType = GetFileType(
                            x.OriginalFileName),

                        Size = x.FileSize,

                        UploadDate = x.CreatedAt,

                        Category = x.Category,

                        UploadedBy = x.UploadedBy,

                        FilePath = BuildFilePath(
                            x.StoragePath,
                            x.OriginalFileName),

                        FolderId = x.FolderId
                    }).ToList();

                ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    // =========================================
    // LOAD FOLDERS
    // =========================================

    private async Task LoadFolders()
    {
        try
        {
            var response =
                await Http.GetFromJsonAsync<List<FolderResponse>>(
                    "http://192.168.11.10:5043/api/folders");

            if (response != null)
            {
                folders =
                    response.Select(x => new FolderItem
                    {
                        Id = x.Id,

                        Name = x.Name,

                        DocumentCount = x.FileCount,

                        LastModified = x.LastModified
                    }).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    // =========================================
    // LOAD CATEGORIES
    // =========================================

    private async Task LoadCategories()
    {
        try
        {
            var response =
                await Http.GetFromJsonAsync<List<CategoryResponse>>(
                    "http://192.168.11.10:5043/api/categories");

            if (response != null)
            {
                categories =
                    response.Select(x => x.Name)
                    .Distinct()
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    // =========================================
    // FILTER DOCUMENTS
    // =========================================

    private void FilterDocuments(string query)
    {
        searchQuery = query;

        ApplyFilters();
    }

    private void FilterByCategory(ChangeEventArgs e)
    {
        selectedCategory =
            e.Value?.ToString() ?? "";

        ApplyFilters();
    }

    private void SortDocuments(ChangeEventArgs e)
    {
        sortBy =
            e.Value?.ToString() ?? "recent";

        ApplyFilters();
    }

    private void ApplyFilters()
    {
        IEnumerable<DocumentItem> result = documents;

        // =====================================
        // FILTER BY FOLDER
        // =====================================

        if (currentFolderId != null)
        {
            result =
                result.Where(x =>
                    x.FolderId == currentFolderId);
        }
        else
        {
            // ROOT DOCUMENTS ONLY
            result =
                result.Where(x =>
                    x.FolderId == null);
        }

        // =====================================
        // SEARCH
        // =====================================

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            result =
                result.Where(x =>
                    x.Name.Contains(
                        searchQuery,
                        StringComparison.OrdinalIgnoreCase));
        }

        // =====================================
        // CATEGORY
        // =====================================

        if (!string.IsNullOrWhiteSpace(selectedCategory))
        {
            result =
                result.Where(x =>
                    x.Category == selectedCategory);
        }

        // =====================================
        // SORTING
        // =====================================

        result = sortBy switch
        {
            "name" =>
                result.OrderBy(x => x.Name),

            "size" =>
                result.OrderByDescending(x => x.Size),

            "oldest" =>
                result.OrderBy(x => x.UploadDate),

            _ =>
                result.OrderByDescending(x => x.UploadDate)
        };

        filteredDocuments =
            result.ToList();
    }

    // =========================================
    // OPEN FOLDER
    // =========================================

    private void OpenFolder(Guid folderId, string folderName)
    {
        currentFolderId = folderId;

        currentFolder = folderName;

        ApplyFilters();
    }

    // =========================================
    // GO BACK TO ROOT
    // =========================================

    private void GoHome()
    {
        currentFolderId = null;

        currentFolder = "";

        ApplyFilters();
    }

    // =========================================
    // CATEGORY
    // =========================================

    private void SelectCategory(string category)
    {
        selectedCategory =
            selectedCategory == category
            ? ""
            : category;

        ApplyFilters();
    }

    private void ClearFilters()
    {
        searchQuery = "";

        selectedCategory = "";

        currentFolder = "";

        currentFolderId = null;

        sortBy = "recent";

        ApplyFilters();
    }

    // =========================================
    // DOCUMENT ACTIONS
    // =========================================

    private void SelectDocument(DocumentItem doc)
    {
    }

    private void ViewDocument(DocumentItem doc)
    {
    }

    private void EditDocument(DocumentItem doc)
    {
    }

    private void ShareDocument(DocumentItem doc)
    {
    }

    private void DownloadDocument(DocumentItem doc)
    {
    }

    private async Task DeleteDocument(DocumentItem doc)
    {
        await Http.DeleteAsync(
            $"http://192.168.11.10:5043/api/documents/{doc.Id}");

        await LoadDocuments();
    }

    // =========================================
    // DELETE FOLDER
    // =========================================

    private async Task DeleteFolder(Guid id)
    {
        await Http.DeleteAsync(
            $"http://192.168.11.10:5043/api/folders/{id}");

        await LoadFolders();

        await LoadDocuments();
    }

    private void ShowUploadModal()
    {
    }

    // =========================================
    // HELPERS
    // =========================================

    private string BuildFilePath(
        string storagePath,
        string fileName)
    {
        if (string.IsNullOrWhiteSpace(storagePath))
        {
            return $"My Documents\\{fileName}";
        }

        storagePath =
            storagePath.Replace("/", "\\");

        return $"{storagePath}\\{fileName}";
    }

    private string GetFileType(string fileName)
    {
        var ext =
            Path.GetExtension(fileName).ToLower();

        return ext switch
        {
            ".pdf" => "pdf",
            ".xls" or ".xlsx" => "excel",
            ".doc" or ".docx" => "word",
            ".ppt" or ".pptx" => "powerpoint",
            ".zip" => "zip",
            ".txt" => "text",
            ".png" or ".jpg" or ".jpeg" => "image",
            ".mp4" => "video",
            _ => "file"
        };
    }

    private string GetFileIcon(string fileType)
    {
        return fileType switch
        {
            "pdf" => "📕",
            "excel" => "📊",
            "word" => "📝",
            "powerpoint" => "🎯",
            "zip" => "📦",
            "text" => "📄",
            "image" => "🖼️",
            "video" => "🎬",
            _ => "📄"
        };
    }

    private string GetFileColor(string fileType)
    {
        return fileType switch
        {
            "pdf" => "#d32f2f",
            "excel" => "#388e3c",
            "word" => "#1976d2",
            "powerpoint" => "#f57c00",
            "zip" => "#7b1fa2",
            "text" => "#616161",
            "image" => "#00bcd4",
            "video" => "#9c27b0",
            _ => "#1f7e3a"
        };
    }

    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Work" => "💼",
            "Personal" => "👤",
            "Finance" => "💰",
            "Legal" => "⚖️",
            "Medical" => "🏥",
            _ => "📁"
        };
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
        {
            return $"{bytes / 1024f / 1024f:0.##} MB";
        }

        return $"{bytes / 1024f:0.##} KB";
    }

    private string GetRelativeTime(DateTime dateTime)
    {
        var timeSpan =
            DateTime.Now - dateTime;

        if (timeSpan.TotalHours < 1)
            return "Just now";

        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";

        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays}d ago";

        return dateTime.ToString("MMM dd");
    }

    // =========================================
    // MODELS
    // =========================================

    public class DocumentItem
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public string FileType { get; set; }

        public long Size { get; set; }

        public DateTime UploadDate { get; set; }

        public string Category { get; set; }

        public string UploadedBy { get; set; }

        public string FilePath { get; set; }

        public Guid? FolderId { get; set; }
    }

    public class FolderItem
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public int DocumentCount { get; set; }

        public DateTime LastModified { get; set; }
    }

    // =========================================
    // API RESPONSES
    // =========================================

    public class DocumentResponse
    {
        public Guid Id { get; set; }

        public string OriginalFileName { get; set; }

        public long FileSize { get; set; }

        public string StoragePath { get; set; }

        public DateTime CreatedAt { get; set; }

        public string Category { get; set; }

        public string UploadedBy { get; set; }

        public Guid? FolderId { get; set; }
    }

    public class FolderResponse
    {
        public Guid Id { get; set; }

        public string Name { get; set; }

        public int FileCount { get; set; }

        public DateTime LastModified { get; set; }
    }

    public class CategoryResponse
    {
        public Guid Id { get; set; }

        public string Name { get; set; }
    }
}
