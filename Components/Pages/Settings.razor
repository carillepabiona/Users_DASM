@page "/profile"
@using System.Text.RegularExpressions
<head>
    <link rel="stylesheet" href="css/settings.css" />
</head>

<div class="settings-container">

    <!-- Header -->
    <div class="settings-header">
        <h1>Profile</h1>
        <p class="subtitle">Manage your account and preferences</p>
    </div>

    <!-- Settings Navigation -->
    <div class="settings-layout">
        <aside class="settings-sidebar">
            <nav class="settings-nav">
                <button class="nav-item @(activeTab == "account" ? "active" : "")" @onclick="@(() => SetTab("account"))">
                    👤 Account
                </button>
                <button class="nav-item @(activeTab == "security" ? "active" : "")" @onclick="@(() => SetTab("security"))">
                    🔒 Security
                </button>
                <button class="nav-item @(activeTab == "notifications" ? "active" : "")" @onclick="@(() => SetTab("notifications"))">
                    🔔 Notifications
                </button>
                <button class="nav-item @(activeTab == "appearance" ? "active" : "")" @onclick="@(() => SetTab("appearance"))">
                    🎨 Appearance
                </button>
                <button class="nav-item @(activeTab == "privacy" ? "active" : "")" @onclick="@(() => SetTab("privacy"))">
                    🛡️ Privacy
                </button>
            </nav>
        </aside>

        <!-- Content Area -->
        <main class="settings-content">
            <!-- Account Settings -->
            @if (activeTab == "account")
            {
                <div class="settings-section">
                    <h2>Account Information</h2>
                    <p class="section-subtitle">Update your account details</p>

                    <div class="profile-card">
                        <div class="profile-header">
                            <div class="profile-avatar">👤</div>
                            <div class="profile-info">
                                <h3>@userProfile.FullName</h3>
                                <p>@userProfile.Email</p>
                            </div>
                            <button class="btn btn-outline" @onclick="@(() => HandleEditProfile())">Edit Profile</button>
                        </div>
                    </div>

                    <div class="setting-item">
                        <div class="setting-label">
                            <h4>Email Address</h4>
                            <p>@userProfile.Email</p>
                        </div>
                        <button class="btn btn-text">Change</button>
                    </div>

                    <div class="setting-item">
                        <div class="setting-label">
                            <h4>Username</h4>
                            <p>@userProfile.Username</p>
                        </div>
                        <button class="btn btn-text">Change</button>
                    </div>

                    <div class="setting-item">
                        <div class="setting-label">
                            <h4>Account Created</h4>
                            <p>@userProfile.CreatedDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Security Settings (Change Password) -->
            @if (activeTab == "security")
            {
                <div class="settings-section">
                    <h2>Security</h2>
                    <p class="section-subtitle">Manage your security preferences</p>

                    <!-- Change Password Card -->
                    <div class="security-card">
                        <div class="card-header">
                            <h3>🔐 Change Password</h3>
                            <p>Update your password to keep your account secure</p>
                        </div>

                        <EditForm Model="@passwordModel" OnValidSubmit="@HandleChangePassword">
                            <DataAnnotationsValidator />

                            <div class="form-group">
                                <label for="currentPassword">Current Password <span class="required">*</span></label>
                                <div class="password-input-wrapper">
                                    <InputText id="currentPassword" type="@(showCurrentPassword ? "text" : "password")"
                                               @bind-Value="@passwordModel.CurrentPassword" class="form-control" placeholder="Enter your current password" />
                                    <button type="button" class="toggle-password" @onclick="@(() => showCurrentPassword = !showCurrentPassword)">
                                        @(showCurrentPassword ? "👁️" : "👁️‍🗨️")
                                    </button>
                                </div>
                                <ValidationMessage For="@(() => passwordModel.CurrentPassword)" />
                            </div>

                            <div class="form-group">
                                <label for="newPassword">New Password <span class="required">*</span></label>
                                <div class="password-input-wrapper">
                                    <InputText id="newPassword" type="@(showNewPassword ? "text" : "password")"
                                               @bind-Value="@passwordModel.NewPassword"
                                               @oninput="@((ChangeEventArgs e) => ValidatePasswordStrength(e.Value?.ToString()))"
                                               class="form-control" placeholder="Create a new password" />
                                    <button type="button" class="toggle-password" @onclick="@(() => showNewPassword = !showNewPassword)">
                                        @(showNewPassword ? "👁️" : "👁️‍🗨️")
                                    </button>
                                </div>
                                <div class="password-strength">
                                    <div class="strength-bar">
                                        <div class="strength-progress @passwordStrengthClass" style="width: @passwordStrengthPercent%"></div>
                                    </div>
                                    <p class="strength-text @passwordStrengthClass">@passwordStrengthText</p>
                                </div>
                                <div class="password-requirements">
                                    <h5>Password Requirements:</h5>
                                    <ul>
                                        <li class="@(passwordModel.NewPassword?.Length >= 8 ? "valid" : "")">✓ At least 8 characters</li>
                                        <li class="@(Regex.IsMatch(passwordModel.NewPassword ?? "", "[A-Z]") ? "valid" : "")">✓ One uppercase letter</li>
                                        <li class="@(Regex.IsMatch(passwordModel.NewPassword ?? "", "[a-z]") ? "valid" : "")">✓ One lowercase letter</li>
                                        <li class="@(Regex.IsMatch(passwordModel.NewPassword ?? "", "[0-9]") ? "valid" : "")">✓ One number</li>
                                        <li class="@(Regex.IsMatch(passwordModel.NewPassword ?? "", "[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]") ? "valid" : "")">✓ One special character</li>
                                    </ul>
                                </div>
                                <ValidationMessage For="@(() => passwordModel.NewPassword)" />
                            </div>

                            <div class="form-group">
                                <label for="confirmPassword">Confirm New Password <span class="required">*</span></label>
                                <div class="password-input-wrapper">
                                    <InputText id="confirmPassword" type="@(showConfirmPassword ? "text" : "password")"
                                               @bind-Value="@passwordModel.ConfirmPassword" class="form-control" placeholder="Re-enter your new password" />
                                    <button type="button" class="toggle-password" @onclick="@(() => showConfirmPassword = !showConfirmPassword)">
                                        @(showConfirmPassword ? "👁️" : "👁️‍🗨️")
                                    </button>
                                </div>
                                <ValidationMessage For="@(() => passwordModel.ConfirmPassword)" />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">Update Password</button>
                                <button type="button" class="btn btn-secondary" @onclick="@(() => ResetPasswordForm())">Cancel</button>
                            </div>

                            @if (!string.IsNullOrEmpty(successMessage))
                            {
                                <div class="alert alert-success">✓ @successMessage</div>
                            }
                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-error">✕ @errorMessage</div>
                            }
                        </EditForm>
                    </div>

                    <!-- Two-Factor Authentication -->
                    <div class="security-card">
                        <div class="card-header">
                            <h3>🔑 Two-Factor Authentication</h3>
                            <p>Add an extra layer of security to your account</p>
                        </div>
                        <div class="setting-item">
                            <div class="setting-label">
                                <h4>Status</h4>
                                <p class="@(userProfile.TwoFactorEnabled ? "text-success" : "text-warning")">
                                    @(userProfile.TwoFactorEnabled ? "✓ Enabled" : "⚠️ Disabled")
                                </p>
                            </div>
                            <button class="btn btn-outline" @onclick="@(() => { })">@(userProfile.TwoFactorEnabled ? "Disable" : "Enable")</button>
                        </div>
                    </div>

                    <!-- Active Sessions -->
                    <div class="security-card">
                        <div class="card-header">
                            <h3>🖥️ Active Sessions</h3>
                            <p>Manage your active login sessions</p>
                        </div>
                        @foreach (var session in activeSessions)
                        {
                            <div class="session-item">
                                <div class="session-info">
                                    <h5>@session.Device</h5>
                                    <p>@session.Location | Last active: @session.LastActive</p>
                                </div>
                                <button class="btn btn-danger-text" @onclick="@((e) => HandleLogoutSession(session.Id))">Sign Out</button>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Notifications Settings -->
            @if (activeTab == "notifications")
            {
                <div class="settings-section">
                    <h2>Notifications</h2>
                    <p class="section-subtitle">Control how you receive notifications</p>

                    <div class="notification-card">
                        <div class="notification-item">
                            <div class="notification-label">
                                <h4>Email Notifications</h4>
                                <p>Receive updates via email</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.EmailNotifications" />
                        </div>

                        <div class="notification-item">
                            <div class="notification-label">
                                <h4>Push Notifications</h4>
                                <p>Receive browser push notifications</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.PushNotifications" />
                        </div>

                        <div class="notification-item">
                            <div class="notification-label">
                                <h4>Marketing Emails</h4>
                                <p>Receive tips, news, and product updates</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.MarketingEmails" />
                        </div>

                        <div class="notification-item">
                            <div class="notification-label">
                                <h4>Activity Digest</h4>
                                <p>Weekly summary of your account activity</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.ActivityDigest" />
                        </div>

                        <div class="form-actions">
                            <button class="btn btn-primary" @onclick="@(() => SaveNotificationSettings())">Save Preferences</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Appearance Settings -->
            @if (activeTab == "appearance")
            {
                <div class="settings-section">
                    <h2>Appearance</h2>
                    <p class="section-subtitle">Customize your experience</p>

                    <div class="appearance-card">
                        <h4>Theme</h4>
                        <div class="theme-options">
                            <button class="theme-btn @(userProfile.Theme == "light" ? "active" : "")" @onclick="@(() => SetTheme("light"))">
                                ☀️ Light
                            </button>
                            <button class="theme-btn @(userProfile.Theme == "dark" ? "active" : "")" @onclick="@(() => SetTheme("dark"))">
                                🌙 Dark
                            </button>
                            <button class="theme-btn @(userProfile.Theme == "auto" ? "active" : "")" @onclick="@(() => SetTheme("auto"))">
                                🔄 Auto
                            </button>
                        </div>
                    </div>

                    <div class="appearance-card">
                        <h4>Language</h4>
                        <select class="form-control" @onchange="@((ChangeEventArgs e) => SetLanguage(e.Value?.ToString()))">
                            <option value="en" selected="@(userProfile.Language == "en")">English</option>
                            <option value="es" selected="@(userProfile.Language == "es")">Spanish</option>
                            <option value="fr" selected="@(userProfile.Language == "fr")">French</option>
                            <option value="de" selected="@(userProfile.Language == "de")">German</option>
                        </select>
                    </div>

                    <div class="appearance-card">
                        <h4>Font Size</h4>
                        <div class="font-size-options">
                            <button class="font-btn @(userProfile.FontSize == "small" ? "active" : "")" @onclick="@(() => SetFontSize("small"))">
                                <span class="font-preview" style="font-size: 12px;">A</span> Small
                            </button>
                            <button class="font-btn @(userProfile.FontSize == "normal" ? "active" : "")" @onclick="@(() => SetFontSize("normal"))">
                                <span class="font-preview" style="font-size: 14px;">A</span> Normal
                            </button>
                            <button class="font-btn @(userProfile.FontSize == "large" ? "active" : "")" @onclick="@(() => SetFontSize("large"))">
                                <span class="font-preview" style="font-size: 16px;">A</span> Large
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Privacy Settings -->
            @if (activeTab == "privacy")
            {
                <div class="settings-section">
                    <h2>Privacy & Data</h2>
                    <p class="section-subtitle">Control your privacy settings</p>

                    <div class="privacy-card">
                        <div class="privacy-item">
                            <div class="privacy-label">
                                <h4>Profile Visibility</h4>
                                <p>Allow others to see your profile</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.ProfilePublic" />
                        </div>

                        <div class="privacy-item">
                            <div class="privacy-label">
                                <h4>Activity Status</h4>
                                <p>Show when you're online</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.ShowActivityStatus" />
                        </div>

                        <div class="privacy-item">
                            <div class="privacy-label">
                                <h4>Allow Messages</h4>
                                <p>Let other users send you messages</p>
                            </div>
                            <input type="checkbox" class="toggle-switch" @bind="@userProfile.AllowMessages" />
                        </div>

                        <div class="form-actions">
                            <button class="btn btn-primary" @onclick="@(() => SavePrivacySettings())">Save Privacy Settings</button>
                        </div>
                    </div>

                    <!-- Data Export -->
                    <div class="privacy-card">
                        <div class="card-header">
                            <h3>📥 Export Your Data</h3>
                            <p>Download a copy of your account data</p>
                        </div>
                        <button class="btn btn-outline" @onclick="@(() => ExportData())">Export All Data</button>
                    </div>

                    <!-- Delete Account -->
                    <div class="privacy-card danger">
                        <div class="card-header">
                            <h3>⚠️ Delete Account</h3>
                            <p>Permanently delete your account and all associated data</p>
                        </div>
                        <p class="warning-text">This action cannot be undone. Please proceed with caution.</p>
                        <button class="btn btn-danger" @onclick="@(() => ShowDeleteConfirmation())">Delete Account</button>
                    </div>
                </div>
            }
        </main>
    </div>
</div>

@code {
    private string activeTab = "account";
    private ChangePasswordModel passwordModel = new();
    private UserProfileModel userProfile = new();
    private List<SessionModel> activeSessions = new();

    private bool showCurrentPassword = false;
    private bool showNewPassword = false;
    private bool showConfirmPassword = false;
    private string successMessage = "";
    private string errorMessage = "";
    private string passwordStrengthText = "";
    private string passwordStrengthClass = "";
    private int passwordStrengthPercent = 0;

    protected override void OnInitialized()
    {
        // Load user profile
        userProfile = new UserProfileModel
        {
            FullName = "John Doe",
            Email = "john.doe@example.com",
            Username = "johndoe",
            CreatedDate = DateTime.Now.AddMonths(-6),
            TwoFactorEnabled = false,
            EmailNotifications = true,
            PushNotifications = true,
            MarketingEmails = false,
            ActivityDigest = true,
            Theme = "light",
            Language = "en",
            FontSize = "normal",
            ProfilePublic = true,
            ShowActivityStatus = true,
            AllowMessages = true
        };

        // Load active sessions
        activeSessions = new List<SessionModel>
        {
            new() { Id = 1, Device = "Chrome - Windows", Location = "New York, USA", LastActive = "Now" },
            new() { Id = 2, Device = "Safari - iPhone", Location = "New York, USA", LastActive = "2 hours ago" },
            new() { Id = 3, Device = "Firefox - MacBook", Location = "Los Angeles, USA", LastActive = "1 day ago" }
        };
    }

    private void SetTab(string tab) => activeTab = tab;

    private void ValidatePasswordStrength(string password)
    {
        passwordModel.NewPassword = password;
        if (string.IsNullOrEmpty(password))
        {
            passwordStrengthText = "";
            passwordStrengthPercent = 0;
            passwordStrengthClass = "";
            return;
        }

        int strength = 0;
        if (password.Length >= 8) strength++;
        if (Regex.IsMatch(password, "[A-Z]")) strength++;
        if (Regex.IsMatch(password, "[a-z]")) strength++;
        if (Regex.IsMatch(password, "[0-9]")) strength++;
        if (Regex.IsMatch(password, "[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]")) strength++;

        passwordStrengthPercent = (strength / 5) * 100;
        passwordStrengthClass = strength switch
        {
            1 => "weak",
            2 => "fair",
            3 => "good",
            4 => "strong",
            5 => "very-strong",
            _ => ""
        };
        passwordStrengthText = strength switch
        {
            1 => "Weak",
            2 => "Fair",
            3 => "Good",
            4 => "Strong",
            5 => "Very Strong",
            _ => ""
        };
    }

    private async Task HandleChangePassword()
    {
        // Validation
        if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
        {
            errorMessage = "New passwords do not match.";
            return;
        }

        if (!IsPasswordStrong(passwordModel.NewPassword))
        {
            errorMessage = "Password does not meet requirements.";
            return;
        }

        // API call (simulate)
        successMessage = "✓ Password updated successfully!";
        errorMessage = "";
        ResetPasswordForm();
    }

    private bool IsPasswordStrong(string password)
    {
        if (string.IsNullOrEmpty(password) || password.Length < 8) return false;
        return Regex.IsMatch(password, "[A-Z]") &&
               Regex.IsMatch(password, "[a-z]") &&
               Regex.IsMatch(password, "[0-9]") &&
               Regex.IsMatch(password, "[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]");
    }

    private void ResetPasswordForm()
    {
        passwordModel = new();
        passwordStrengthText = "";
        passwordStrengthPercent = 0;
        passwordStrengthClass = "";
    }

    private void HandleEditProfile() => Console.WriteLine("Edit profile");
    private void HandleLogoutSession(int id) => activeSessions.RemoveAll(s => s.Id == id);
    private void SaveNotificationSettings() => Console.WriteLine("Notifications saved");
    private void SetTheme(string theme) => userProfile.Theme = theme;
    private void SetLanguage(string lang) => userProfile.Language = lang;
    private void SetFontSize(string size) => userProfile.FontSize = size;
    private void SavePrivacySettings() => Console.WriteLine("Privacy settings saved");
    private void ExportData() => Console.WriteLine("Exporting data...");
    private void ShowDeleteConfirmation() => Console.WriteLine("Show delete confirmation");

    public class ChangePasswordModel
    {
        public string CurrentPassword { get; set; }
        public string NewPassword { get; set; }
        public string ConfirmPassword { get; set; }
    }

    public class UserProfileModel
    {
        public string FullName { get; set; }
        public string Email { get; set; }
        public string Username { get; set; }
        public DateTime CreatedDate { get; set; }
        public bool TwoFactorEnabled { get; set; }
        public bool EmailNotifications { get; set; }
        public bool PushNotifications { get; set; }
        public bool MarketingEmails { get; set; }
        public bool ActivityDigest { get; set; }
        public string Theme { get; set; }
        public string Language { get; set; }
        public string FontSize { get; set; }
        public bool ProfilePublic { get; set; }
        public bool ShowActivityStatus { get; set; }
        public bool AllowMessages { get; set; }
    }

    public class SessionModel
    {
        public int Id { get; set; }
        public string Device { get; set; }
        public string Location { get; set; }
        public string LastActive { get; set; }
    }
}