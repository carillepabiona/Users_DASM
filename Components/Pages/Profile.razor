@page "/profile"
@using Users_DASM.Models
@using System.Text.RegularExpressions
@using System.Net.Http.Json
@using Users_DASM.Services
@inject CurrentUserService CurrentUserService
@inject HttpClient Http

<head>
    <link rel="stylesheet" href="css/settings.css" />
</head>

<div class="settings-container">

    <!-- HEADER -->
    <div class="settings-header">
        <h1>Profile</h1>
        <p class="subtitle">
            Manage your account and preferences
        </p>
    </div>

    <!-- LAYOUT -->
    <div class="settings-layout">

        <!-- SIDEBAR -->
        <aside class="settings-sidebar">

            <nav class="settings-nav">

                <button class="nav-item @(activeTab == "account" ? "active" : "")"
                        @onclick="@(() => SetTab("account"))">

                    👤 Account

                </button>

                <button class="nav-item @(activeTab == "security" ? "active" : "")"
                        @onclick="@(() => SetTab("security"))">

                    🔒 Security

                </button>

            </nav>

        </aside>

        <!-- CONTENT -->
        <main class="settings-content">

            <!-- ACCOUNT -->
            @if (activeTab == "account")
            {
                <div class="settings-section">

                    <h2>Account Information</h2>

                    <p class="section-subtitle">
                        Update your account details
                    </p>

                    <!-- PROFILE CARD -->
                    <div class="profile-card">

                        <div class="profile-header">

                            <!-- AVATAR -->
                            <div class="profile-avatar">
                                @avatarInitial
                            </div>

                            <!-- INFO -->
                            <div class="profile-info">

                                <h3>@userProfile.FullName</h3>

                                <p>@userProfile.Email</p>

                            </div>

                            <!-- EDIT BUTTON -->
                            @if (!isEditingProfile)
                            {
                                <button class="btn btn-outline"
                                        @onclick="EnableEditProfile">

                                    Edit Profile

                                </button>
                            }

                        </div>

                    </div>

                    <!-- USERNAME -->
                    <div class="setting-item">

                        <div class="setting-label">

                            <h4>Username</h4>

                            <p>@userProfile.Username</p>

                        </div>

                    </div>

                    <!-- EMAIL -->
                    <div class="setting-item">

                        <div class="setting-label">

                            <h4>Email Address</h4>

                            <p>@userProfile.Email</p>

                        </div>

                    </div>

                    <!-- CONTACT -->
                    <div class="setting-item">

                        <div class="setting-label">

                            <h4>Contact Number</h4>

                            @if (isEditingProfile)
                            {
                                <InputText class="form-control"
                                           @bind-Value="userProfile.ContactNumber" />
                            }
                            else
                            {
                                <p>@userProfile.ContactNumber</p>
                            }

                        </div>

                    </div>

                    <!-- ADDRESS -->
                    <div class="setting-item">

                        <div class="setting-label">

                            <h4>Address</h4>

                            @if (isEditingProfile)
                            {
                                <InputText class="form-control"
                                           @bind-Value="userProfile.Address" />
                            }
                            else
                            {
                                <p>@userProfile.Address</p>
                            }

                        </div>

                    </div>

                    <!-- ROLE -->
                    <div class="setting-item">

                        <div class="setting-label">

                            <h4>Role</h4>

                            <p>@userProfile.Role</p>

                        </div>

                    </div>

                    <!-- CREATED -->
                    <div class="setting-item">

                        <div class="setting-label">

                            <h4>Account Created</h4>

                            <p>
                                @userProfile.CreatedDate.ToString("MMMM dd, yyyy")
                            </p>

                        </div>

                    </div>

                    <!-- ACTION BUTTONS -->
                    @if (isEditingProfile)
                    {
                        <div class="form-actions">

                            <button class="btn btn-primary"
                                    @onclick="SaveProfile">

                                Save Changes

                            </button>

                            <button class="btn btn-secondary"
                                    @onclick="CancelEditProfile">

                                Cancel

                            </button>

                        </div>
                    }

                    <!-- SUCCESS -->
                    @if (!string.IsNullOrEmpty(profileSuccessMessage))
                    {
                        <div class="alert alert-success">
                            @profileSuccessMessage
                        </div>
                    }

                    <!-- ERROR -->
                    @if (!string.IsNullOrEmpty(profileErrorMessage))
                    {
                        <div class="alert alert-error">
                            @profileErrorMessage
                        </div>
                    }

                </div>
            }

            <!-- SECURITY -->
            @if (activeTab == "security")
            {
                <div class="settings-section">

                    <h2>Security</h2>

                    <p class="section-subtitle">
                        Manage your security preferences
                    </p>

                    <div class="security-card">

                        <div class="card-header">

                            <h3>🔐 Change Password</h3>

                            <p>
                                Update your password to keep your account secure
                            </p>

                        </div>

                        <EditForm Model="@passwordModel"
                                  OnValidSubmit="@HandleChangePassword">

                            <DataAnnotationsValidator />

                            <!-- CURRENT PASSWORD -->
                            <div class="form-group">

                                <label>
                                    Current Password
                                </label>

                                <InputText type="password"
                                           @bind-Value="@passwordModel.CurrentPassword"
                                           class="form-control" />

                            </div>

                            <!-- NEW PASSWORD -->
                            <div class="form-group">

                                <label>
                                    New Password
                                </label>

                                <InputText type="password"
                                           @bind-Value="@passwordModel.NewPassword"
                                           class="form-control" />

                            </div>

                            <!-- CONFIRM -->
                            <div class="form-group">

                                <label>
                                    Confirm Password
                                </label>

                                <InputText type="password"
                                           @bind-Value="@passwordModel.ConfirmPassword"
                                           class="form-control" />

                            </div>

                            <!-- BUTTONS -->
                            <div class="form-actions">

                                <button type="submit"
                                        class="btn btn-primary">

                                    Update Password

                                </button>

                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="@(() => ResetPasswordForm())">

                                    Cancel

                                </button>

                            </div>

                            <!-- SUCCESS -->
                            @if (!string.IsNullOrEmpty(successMessage))
                            {
                                <div class="alert alert-success">
                                    @successMessage
                                </div>
                            }

                            <!-- ERROR -->
                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-error">
                                    @errorMessage
                                </div>
                            }

                        </EditForm>

                    </div>

                </div>
            }

        </main>

    </div>

</div>

@code {

    // =========================================
    // UI
    // =========================================

    private string activeTab = "account";

    private string avatarInitial = "?";

    private string successMessage = "";

    private string errorMessage = "";

    private bool isEditingProfile = false;

    private string profileSuccessMessage = "";

    private string profileErrorMessage = "";

    // =========================================
    // MODELS
    // =========================================

    private ChangePasswordModel passwordModel = new();

    private UserProfileModel userProfile = new();

    // =========================================
    // INITIALIZE
    // =========================================

    protected override async Task OnInitializedAsync()
    {
        var currentUser =
            await CurrentUserService.GetUser();

        if (currentUser == null)
        {
            return;
        }

        userProfile = new UserProfileModel
        {
            Id = currentUser.Id,

            FullName = currentUser.FullName,

            Username = currentUser.Username,

            Email = currentUser.Email,

            ContactNumber = currentUser.ContactNumber,

            Address = currentUser.Address,

            Role = currentUser.RoleId switch
            {
                1 => "Administrator",

                2 => "Civilian Personnel",

                3 => "Military Personnel",

                _ => "Unknown Role"
            },

            CreatedDate = currentUser.CreatedAt
        };

        avatarInitial =
            !string.IsNullOrWhiteSpace(
                currentUser.FullName)
            ? currentUser.FullName
                .Substring(0, 1)
                .ToUpper()
            : "?";
    }

    // =========================================
    // TABS
    // =========================================

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    // =========================================
    // PROFILE EDIT
    // =========================================

    private void EnableEditProfile()
    {
        isEditingProfile = true;

        profileSuccessMessage = "";

        profileErrorMessage = "";
    }

    private void CancelEditProfile()
    {
        isEditingProfile = false;

        profileSuccessMessage = "";

        profileErrorMessage = "";
    }

    // =========================================
    // SAVE PROFILE
    // =========================================

    private async Task SaveProfile()
    {
        try
        {
            var currentUser =
                await CurrentUserService.GetUser();

            if (currentUser == null)
            {
                profileErrorMessage =
                    "User session not found.";

                return;
            }

            // =====================================
            // REQUEST
            // =====================================

            var updateRequest =
                new UpdateProfileRequest
                {
                    ContactNumber =
                        userProfile.ContactNumber,

                    Address =
                        userProfile.Address
                };

            // =====================================
            // API CALL
            // =====================================

            var response =
                await Http.PutAsJsonAsync(
                    $"api/users/update-profile/{currentUser.Id}",
                    updateRequest);

            if (!response.IsSuccessStatusCode)
            {
                profileErrorMessage =
                    await response.Content
                        .ReadAsStringAsync();

                return;
            }

            // =====================================
            // UPDATE SESSION
            // =====================================

            currentUser.ContactNumber =
                userProfile.ContactNumber;

            currentUser.Address =
                userProfile.Address;

            await CurrentUserService
                .SaveUser(currentUser);

            // =====================================
            // SUCCESS
            // =====================================

            profileSuccessMessage =
                "Profile updated successfully.";

            profileErrorMessage = "";

            isEditingProfile = false;
        }
        catch (Exception ex)
        {
            profileErrorMessage = ex.Message;
        }
    }

    // =========================================
    // CHANGE PASSWORD
    // =========================================

    private async Task HandleChangePassword()
    {
        successMessage = "";

        errorMessage = "";

        // =====================================
        // CHECK MATCH
        // =====================================

        if (passwordModel.NewPassword !=
            passwordModel.ConfirmPassword)
        {
            errorMessage =
                "Passwords do not match.";

            return;
        }

        // =====================================
        // CHECK STRENGTH
        // =====================================

        if (!IsPasswordStrong(
            passwordModel.NewPassword))
        {
            errorMessage =
                "Password does not meet requirements.";

            return;
        }

        try
        {
            var currentUser =
                await CurrentUserService.GetUser();

            if (currentUser == null)
            {
                errorMessage =
                    "User session not found.";

                return;
            }

            // =================================
            // REQUEST
            // =================================

            var request =
                new ChangePasswordRequest
                {
                    CurrentPassword =
                        passwordModel.CurrentPassword,

                    NewPassword =
                        passwordModel.NewPassword
                };

            // =================================
            // API CALL
            // =================================

            var response =
                await Http.PutAsJsonAsync(
                    $"api/users/change-password/{currentUser.Id}",
                    request);

            if (response.IsSuccessStatusCode)
            {
                successMessage =
                    "Password updated successfully.";

                errorMessage = "";

                ResetPasswordForm();
            }
            else
            {
                errorMessage =
                    await response.Content
                        .ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    // =========================================
    // PASSWORD VALIDATION
    // =========================================

    private bool IsPasswordStrong(string password)
    {
        if (string.IsNullOrEmpty(password) ||
            password.Length < 8)
        {
            return false;
        }

        return Regex.IsMatch(password, "[A-Z]") &&
               Regex.IsMatch(password, "[a-z]") &&
               Regex.IsMatch(password, "[0-9]") &&
               Regex.IsMatch(
                   password,
                   "[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]");
    }

    // =========================================
    // RESET PASSWORD FORM
    // =========================================

    private void ResetPasswordForm()
    {
        passwordModel = new();
    }
}